generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum CourseCategory {
  HANDS_ON
  ONLINE
  HYBRID
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  MERCADO_PAGO_PIX
  MERCADO_PAGO_BOLETO
  MERCADO_PAGO_CARD
  ASAAS_PIX
  ASAAS_BOLETO
  ASAAS_CARD
  FREE
}

enum LessonType {
  VIDEO
  LIVE
  TEXT
  QUIZ
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

// ─── USERS & AUTH ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  phone         String?
  role          Role      @default(STUDENT)
  bio           String?
  specialty     String?
  crm           String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  enrollments       Enrollment[]
  notes             Note[]
  quizAttempts      QuizAttempt[]
  certificates      Certificate[]
  chatHistory       ChatMessage[]
  instructor        Instructor?
  attendancesMade   Attendance[]  @relation("AttendanceMarkedBy")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── INSTRUCTORS ──────────────────────────────────────────────────────────────

model Instructor {
  id          String   @id @default(cuid())
  userId      String   @unique
  title       String?
  crm         String?
  rqe         String?
  photoUrl    String?
  slug        String   @unique
  bio         String?  @db.Text
  formation   String?  // Ex: "Doutora pela UFMG · Especialista em Gastroenterologia"
  institution String?  // Ex: "Hospital Albert Einstein"
  linkedin     String?  // URL LinkedIn
  instagram    String?  // URL Instagram
  lattes       String?  // URL Lattes CNPq (mantido para retrocompatibilidade)
  displayOrder Int      @default(99)  // ordem de exibição nas páginas públicas
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courses Course[]
}

// ─── COURSES ──────────────────────────────────────────────────────────────────

model Course {
  id            String         @id @default(cuid())
  slug          String         @unique
  title         String
  description   String         @db.Text
  shortDesc     String?
  thumbnailUrl  String?
  previewUrl    String?
  contentUrl          String?   // link do conteúdo online (YouTube, Vimeo, plataforma externa)
  externalCheckoutUrl String?   // quando preenchido, o botão de compra redireciona para URL externa
  price         Decimal        @db.Decimal(10, 2)
  salePrice     Decimal?       @db.Decimal(10, 2)
  hours         Int
  category      CourseCategory
  status        CourseStatus   @default(DRAFT)
  instructorId  String
  totalSeats    Int?
  reservedSeats Int            @default(0)
  startDate     DateTime?
  endDate       DateTime?
  location      String?
  metaTitle     String?
  metaDesc      String?

  // Conteúdo detalhado da página do curso (uma entrada por linha, separadas por \n)
  objectives     String?   @db.Text  // O que você vai aprender
  targetAudience String?   @db.Text  // Público-alvo
  includes       String?   @db.Text  // O que está incluído
  startDateLabel String?             // Ex: "15–19 de junho de 2026"

  // Co-instrutor (opcional — para cursos em parceria com convidados externos)
  coInstructorName       String?
  coInstructorCredential String?           // Ex: "Médico | CRM – 22052"
  coInstructorPhotoUrl   String?
  coInstructorBio        String?   @db.Text
  coInstructorInstagram  String?

  // Translations (nullable — fill only when a translation is available)
  titleEn        String?
  shortDescEn    String?
  descriptionEn  String?   @db.Text
  titleEs        String?
  shortDescEs    String?
  descriptionEs  String?   @db.Text

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  instructor    Instructor     @relation(fields: [instructorId], references: [id])
  modules       Module[]
  enrollments   Enrollment[]
  coupons       CouponUsage[]
  tags          CourseTag[]
  liveSessions  LiveSession[]
}

model Tag {
  id      String      @id @default(cuid())
  name    String      @unique
  slug    String      @unique
  courses CourseTag[]
}

model CourseTag {
  courseId String
  tagId    String

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([courseId, tagId])
}

// ─── MODULES & LESSONS ────────────────────────────────────────────────────────

model Module {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]
}

model Lesson {
  id           String     @id @default(cuid())
  moduleId     String
  title        String
  description  String?    @db.Text
  type         LessonType @default(VIDEO)
  videoUrl     String?
  muxAssetId   String?
  muxPlaybackId String?
  duration     Int?
  order        Int
  isFree       Boolean    @default(false)
  liveUrl      String?
  liveDate     DateTime?
  content      String?    @db.Text
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  module    Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  materials Material[]
  quiz      Quiz?
  progress  Progress[]
  notes     Note[]
}

model Material {
  id        String   @id @default(cuid())
  lessonId  String
  title     String
  fileUrl   String
  fileType  String
  sizeBytes Int?
  createdAt DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

// ─── ENROLLMENTS & PROGRESS ───────────────────────────────────────────────────

model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  courseId    String
  status      EnrollmentStatus @default(ACTIVE)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  expiresAt   DateTime?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course   Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  payments    Payment[]
  progress    Progress[]
  certificate Certificate?
  attendances Attendance[]

  @@unique([userId, courseId])
}

model Progress {
  id           String   @id @default(cuid())
  enrollmentId String
  lessonId     String
  completed    Boolean  @default(false)
  watchedSecs  Int      @default(0)
  completedAt  DateTime?
  updatedAt    DateTime @updatedAt

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
}

// ─── ATTENDANCE ───────────────────────────────────────────────────────────────

model Attendance {
  id           String           @id @default(cuid())
  enrollmentId String
  date         DateTime         @db.Date
  status       AttendanceStatus @default(ABSENT)
  markedById   String
  markedAt     DateTime         @default(now())
  notes        String?

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  markedBy   User       @relation("AttendanceMarkedBy", fields: [markedById], references: [id])

  @@unique([enrollmentId, date])
}

// ─── PAYMENTS ─────────────────────────────────────────────────────────────────

model Payment {
  id             String        @id @default(cuid())
  enrollmentId   String
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("BRL")
  stripeIntentId  String?
  mpPaymentId     String?
  mpOrderId       String?
  asaasPaymentId  String?
  receiptUrl     String?
  nfseId         String?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
}

// ─── COUPONS ──────────────────────────────────────────────────────────────────

model Coupon {
  id           String    @id @default(cuid())
  code         String    @unique
  discountPct  Int?
  discountFlat Decimal?  @db.Decimal(10, 2)
  maxUses      Int?
  usesCount    Int       @default(0)
  expiresAt    DateTime?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())

  usages CouponUsage[]
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String
  courseId  String
  userId    String
  usedAt    DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

// ─── QUIZZES ──────────────────────────────────────────────────────────────────

model Quiz {
  id        String     @id @default(cuid())
  lessonId  String     @unique
  title     String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  lesson    Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  QuizAttempt[]
}

model Question {
  id       String   @id @default(cuid())
  quizId   String
  text     String   @db.Text
  order    Int
  options  Option[]

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model Option {
  id         String   @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean  @default(false)
  order      Int

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id        String   @id @default(cuid())
  userId    String
  quizId    String
  score     Int
  total     Int
  answers   Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

// ─── CERTIFICATES ─────────────────────────────────────────────────────────────

model Certificate {
  id           String   @id @default(cuid())
  userId       String
  enrollmentId String   @unique
  code         String   @unique @default(cuid())
  issueDate    DateTime @default(now())
  pdfUrl       String?
  blockchainTx String?

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
}

// ─── NOTES & AI CHAT ──────────────────────────────────────────────────────────

model Note {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String   @db.Text
  context   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── PLATFORM SETTINGS ───────────────────────────────────────────────────────

model PlatformSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// ─── LIVE SESSIONS ────────────────────────────────────────────────────────────

model LiveSession {
  id          String    @id @default(cuid())
  courseId    String
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  meetUrl      String?
  location     String?
  recordingUrl String?
  reminder24h Boolean   @default(false)
  reminder1h  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}
