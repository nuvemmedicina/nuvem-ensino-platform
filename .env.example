# ─── DATABASE ────────────────────────────────────────────────────────────────
# Neon PostgreSQL (https://neon.tech)
DATABASE_URL="postgresql://user:password@host/nuvem_ensino?sslmode=require"

# ─── AUTH.JS ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
AUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── STRIPE (pagamentos internacionais) ───────────────────────────────────────
STRIPE_PUBLIC_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── MERCADO PAGO (PIX / boleto / parcelamento) ───────────────────────────────
MP_ACCESS_TOKEN="APP_USR-..."
MP_PUBLIC_KEY="APP_USR-..."
MP_WEBHOOK_SECRET="your-mp-webhook-secret"

# ─── RESEND (emails transacionais) ────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="Nuvem Ensino <cursos@nuvemensino.com.br>"

# ─── MUX (hospedagem de vídeos) ───────────────────────────────────────────────
MUX_TOKEN_ID="your-mux-token-id"
MUX_TOKEN_SECRET="your-mux-token-secret"
MUX_WEBHOOK_SECRET="your-mux-webhook-secret"

# ─── ANTHROPIC (chat com IA) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── GOOGLE CALENDAR (aulas ao vivo) ─────────────────────────────────────────
GOOGLE_CALENDAR_ID="your-calendar-id"

# ─── CRON ────────────────────────────────────────────────────────────────────
# Protege o endpoint /api/cron/reminders contra acesso não autorizado
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CRON_SECRET="your-cron-secret-here"

# ─── SENTRY (monitoramento de erros) ─────────────────────────────────────────
# DSN disponível em: sentry.io → Settings → Projects → Client Keys
NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
# Auth token para upload de source maps no CI/CD (NÃO commitar)
SENTRY_AUTH_TOKEN="sntrys_..."

# ─── POSTHOG (analytics) ─────────────────────────────────────────────────────
# Disponível em: posthog.com → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY="phc_..."
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# ─── APP ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
